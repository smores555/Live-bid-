<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>737 Master Bid Control - Hard Cap Edition</title>
    <style>
        :root { --bg: #0b0e14; --card: #161b22; --text: #c9d1d9; --accent: #58a6ff; --border: #30363d; --green: #3fb950; --red: #f85149; --yellow: #ffd33d; --purple: #bc8cff; }
        body { font-family: -apple-system, sans-serif; background: var(--bg); color: var(--text); padding: 20px; margin: 0; line-height: 1.5; }
        .container { max-width: 1600px; margin: 0 auto; }
        .card { background: var(--card); padding: 15px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 20px; }
        .cap-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; margin-top: 10px; }
        .cap-cell { display: flex; flex-direction: column; font-size: 0.7rem; }
        .cap-cell input { background: #0d1117; border: 1px solid var(--border); color: #4ade80; padding: 5px; border-radius: 4px; font-weight: bold; }
        .toolbar { display: flex; align-items: center; gap: 10px; background: var(--card); padding: 15px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 20px; flex-wrap: wrap; }
        .btn { background: var(--accent); color: white; border: none; padding: 10px 18px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 0.85rem; }
        .dash-container { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 15px; margin-bottom: 20px; }
        .dash-box { background: #1a1d23; border: 1px solid var(--border); padding: 15px; border-radius: 8px; height: 300px; overflow-y: auto; }
        .dash-title { margin: 0 0 10px 0; font-size: 0.85rem; font-weight: bold; text-transform: uppercase; }
        .unassigned-item { background: #1b122a; border-left: 4px solid var(--purple); padding: 8px; margin-bottom: 8px; font-size: 0.75rem; color: #eee; }
        .self-disp-item { background: #2a1212; border-left: 4px solid var(--red); padding: 8px; margin-bottom: 8px; font-size: 0.75rem; color: #eee; }
        .disp-item { background: #2a2612; border-left: 4px solid var(--yellow); padding: 8px; margin-bottom: 8px; font-size: 0.75rem; color: #eee; }
        table { width: 100%; border-collapse: collapse; background: var(--card); border-radius: 8px; border: 1px solid var(--border); }
        th { background: #21262d; color: var(--accent); text-align: left; padding: 12px; font-size: 0.8rem; }
        td { padding: 12px; border-bottom: 1px solid var(--border); font-size: 0.85rem; vertical-align: top; }
        .tag { padding: 2px 6px; border-radius: 4px; font-size: 0.6rem; font-weight: 900; margin-left: 5px; text-transform: uppercase; display: inline-block; }
        .tag-red { background: var(--red); color: white; }
        .tag-yellow { background: var(--yellow); color: #000; }
        .rank-badge { background: #30363d; padding: 3px 7px; border-radius: 4px; color: #4ade80; font-weight: bold; font-size: 0.85rem; border: 1px solid #444; }
        .bid-log { display: block; font-size: 0.7rem; color: #8b949e; line-height: 1.2; margin-top: 5px; }
        .log-success { color: #4ade80; font-weight: bold; }
        .log-fail { color: #f85149; }
    </style>
</head>
<body>

<div class="container">
    <div class="card">
        <h3 style="margin:0">Position Deltas (737 Fleet)</h3>
        <div id="capGrid" class="cap-grid">Loading...</div>
    </div>

    <div class="dash-container">
        <div class="dash-box">
            <h4 class="dash-title" style="color:var(--accent)">⚙️ Engine Status</h4>
            <div id="statusBox" style="font-size: 0.75rem;">Idle.</div>
        </div>
        <div class="dash-box">
            <h4 class="dash-title" style="color:var(--yellow)">⚠️ MOVER Pilots</h4>
            <div id="displacedList">Ready...</div>
        </div>
        <div class="dash-box">
            <h4 class="dash-title" style="color:var(--purple)">🆘 DISPLACED</h4>
            <div id="unassignedList">Ready...</div>
        </div>
        <div class="dash-box">
            <h4 class="dash-title" style="color:var(--red)">🛑 BPL Failures</h4>
            <div id="selfDispList">Ready...</div>
        </div>
    </div>

    <div class="toolbar">
        <button id="runBtn" class="btn">RUN MASTER POSITION BID</button>
        <button id="expBase" class="btn">CSV: BASE LIST</button>
        <button id="expMaster" class="btn">CSV: MASTER AWARDS</button>
        <button id="expLog" class="btn">CSV: TRANSITION LOG</button>
        <div style="flex-grow:1"></div>
        <input type="number" id="lookupInput" style="padding:10px; background:#0d1117; color:white; border:1px solid var(--border); border-radius:6px; width:120px;" placeholder="Sen #">
        <button id="lookupBtn" class="btn">LOOKUP</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>Sen #</th>
                <th>Pilot Name</th>
                <th>Awarded Position</th>
                <th>Final Standing (Rank / Limit)</th>
                <th>Award Path & Evaluation Log</th>
                <th>Original Position</th>
            </tr>
        </thead>
        <tbody id="tableBody"></tbody>
    </table>
</div>

<script>
let store = { roster: [], prefs: {}, caps: [], retired: [], noBid: [] };
let lastResults = [];
let lastTargetMap = {};

function runBidEngine(data, deltaMap) {
    const is737 = (seat) => seat && !seat.includes('320') && !seat.includes('321');
    const retiredSens = new Set(data.retired.filter(p => is737(p.seat)).map(p => p.seniority));
    const noBidSens = new Set(data.noBid.filter(p => is737(p.seat)).map(p => p.sen));
    const activeBidders = data.roster.filter(p => is737(p.current.seat) && !retiredSens.has(p.sen) && !noBidSens.has(p.sen));

    let liveHeadcount = {};
    activeBidders.forEach(p => {
        const key = `${p.current.base}-${p.current.seat}`.toUpperCase();
        liveHeadcount[key] = (liveHeadcount[key] || 0) + 1;
    });

    let targetMap = {};
    Object.keys(liveHeadcount).forEach(key => {
        targetMap[key] = liveHeadcount[key] + (deltaMap[key] || 0);
        // APPLY HARD CAPS
        if (key === "LAX-CA") targetMap[key] = 189;
        if (key === "SFO-CA") targetMap[key] = 153;
    });
    data.caps.forEach(c => {
        const key = `${c.base}-${c.seat}`.toUpperCase();
        if (targetMap[key] === undefined) {
            targetMap[key] = c.startCapacity + (deltaMap[key] || 0);
            if (key === "LAX-CA") targetMap[key] = 189;
            if (key === "SFO-CA") targetMap[key] = 153;
        }
    });

    let currentCounts = { ...liveHeadcount };

    const bidders = activeBidders.map(p => {
        const prefData = data.prefs['pil' + p.sen] || data.prefs[p.id] || { preferences: [] };
        const pilotOrig = `${p.current.base}-${p.current.seat}`.toUpperCase();
        const getTargetKey = (bidStr) => {
            const parts = bidStr.trim().toUpperCase().split(/\s+/);
            const bases = ['ANC', 'SEA', 'LAX', 'SAN', 'SFO', 'PDX', 'LAS'];
            const seats = ['CA', 'FO'];
            let b = parts.find(x => bases.includes(x));
            let s = parts.find(x => seats.includes(x));
            return (b && s) ? `${b}-${s}` : null;
        };

        return {
            ...p, orig: pilotOrig, currentKey: pilotOrig, moved: false, isUnassigned: false, awardedPrefNum: "N/A", awardedReason: "", wasSelfDisplaced: false, bidLog: [],
            prefs: (prefData.preferences || []).map(pr => {
                let limit = parseInt(pr.bpl || pr.bpl_min);
                if (isNaN(limit) || limit === 0) limit = 9999;
                return { ...pr, targetKey: getTargetKey(pr.bid), bpl: limit };
            }).sort((a, b) => a.order - b.order)
        };
    }).sort((a, b) => a.sen - b.sen);

    bidders.forEach(p => {
        let awarded = false;
        const [origBase, origStatus] = p.orig.split('-');

        // Step A: Primary Preference Eval
        for (const pr of p.prefs) {
            if (!pr.targetKey) {
                p.bidLog.push(`<div class="log-fail">Pref #${pr.order}: Invalid Bid String (${pr.bid})</div>`);
                continue;
            }
            let cap = targetMap[pr.targetKey] || 0;
            let seniorOccupancy = bidders.filter(other => other.sen < p.sen && other.currentKey === pr.targetKey).length;
            let rank = seniorOccupancy + 1;

            if (seniorOccupancy >= cap) {
                p.bidLog.push(`<div class="log-fail">Pref #${pr.order} (${pr.targetKey}): Denied (Base Full at ${cap})</div>`);
                continue;
            }
            if (rank > pr.bpl) {
                p.bidLog.push(`<div class="log-fail">Pref #${pr.order} (${pr.targetKey}): Denied (BPL Rank ${rank} > Limit ${pr.bpl})</div>`);
                continue;
            }

            // SUCCESS
            let targetOldVac = cap - (currentCounts[pr.targetKey] || 0);
            let origOldVac = (targetMap[p.orig] || 0) - currentCounts[p.orig];
            
            if (p.orig !== pr.targetKey) {
                currentCounts[p.orig]--;
                currentCounts[pr.targetKey] = (currentCounts[pr.targetKey] || 0) + 1;
                p.moved = true;
                
                let targetNewVac = cap - currentCounts[pr.targetKey];
                let origNewVac = (targetMap[p.orig] || 0) - currentCounts[p.orig];

                p.awardedReason = targetOldVac > 0 ? 
                    `Awarded Pref #${pr.order} via Vacancy. Reduce ${pr.targetKey} vacancy ${targetOldVac} → ${targetNewVac}. Increase ${p.orig} vacancy ${origOldVac} → ${origNewVac}.` : 
                    `Awarded Pref #${pr.order} (Displaced Junior Pilot). Increase ${p.orig} vacancy ${origOldVac} → ${origNewVac}.`;
            } else {
                p.awardedReason = `Awarded Preference #${pr.order}. Remained in current position.`;
                p.moved = false;
            }
            
            p.currentKey = pr.targetKey;
            p.awardedPrefNum = pr.order;
            p.bidLog.push(`<div class="log-success">Pref #${pr.order} (${pr.targetKey}): Awarded</div>`);
            awarded = true;
            break;
        }

        // Step B: Seniority Hold Eval
        if (!awarded) {
            let seniorsInMyBase = bidders.filter(other => other.sen < p.sen && other.currentKey === p.orig).length;
            let rank = seniorsInMyBase + 1;
            const selfBid = p.prefs.find(pr => pr.targetKey === p.orig);
            let bplLimit = selfBid ? selfBid.bpl : 9999;

            if (seniorsInMyBase < (targetMap[p.orig] || 0) && rank <= bplLimit) {
                p.currentKey = p.orig;
                p.awardedReason = `Held Position (Seniority). Vacancy remains at ${(targetMap[p.orig] || 0) - currentCounts[p.orig]}.`;
                p.bidLog.push(`<div class="log-success">Static Hold (${p.orig}): Awarded</div>`);
                p.moved = false;
                awarded = true;
            } else {
                p.bidLog.push(`<div class="log-fail">Static Hold (${p.orig}): Denied (Rank ${rank} Exceeds Capacity/BPL)</div>`);
            }
        }

        // Step C: Section 24 Eval
        if (!awarded) {
            const cascadeOptions = [...['ANC', 'SEA', 'LAX', 'SAN', 'SFO', 'PDX', 'LAS'].filter(b => b !== origBase).map(b => `${b}-${origStatus}`), `${origBase}-FO`, ...['ANC', 'SEA', 'LAX', 'SAN', 'SFO', 'PDX', 'LAS'].filter(b => b !== origBase).map(b => `${b}-FO`)];
            for (const targetKey of cascadeOptions) {
                if (targetMap[targetKey] === undefined) continue;
                let cap = targetMap[targetKey] || 0;
                let seniorCount = bidders.filter(other => other.sen < p.sen && other.currentKey === targetKey).length;

                if (seniorCount < cap) {
                    let targetOldVac = cap - (currentCounts[targetKey] || 0);
                    let origOldVac = (targetMap[p.orig] || 0) - currentCounts[p.orig];

                    currentCounts[p.orig]--;
                    currentCounts[targetKey]++;

                    let targetNewVac = cap - currentCounts[targetKey];
                    let origNewVac = (targetMap[p.orig] || 0) - currentCounts[p.orig];

                    p.currentKey = targetKey;
                    p.awardedReason = targetOldVac > 0 ? 
                        `Section 24 Displacement: Awarded ${targetKey}. Reduce vacancy ${targetOldVac} → ${targetNewVac}. Increase ${p.orig} vacancy ${origOldVac} → ${origNewVac}.` : 
                        `Section 24 Displacement: Displaced Junior Pilot in ${targetKey}. Increase ${p.orig} vacancy ${origOldVac} → ${origNewVac}.`;
                    
                    p.bidLog.push(`<div class="log-success">Section 24 (${targetKey}): Awarded</div>`);
                    p.moved = true;
                    awarded = true;
                    break;
                } else {
                    p.bidLog.push(`<div class="log-fail">Section 24 (${targetKey}): Denied (Full)</div>`);
                }
            }
        }

        // Step D: Pool Eval
        if (!awarded) {
            let origOldVac = (targetMap[p.orig] || 0) - currentCounts[p.orig];
            currentCounts[p.orig]--; 
            let origNewVac = (targetMap[p.orig] || 0) - currentCounts[p.orig];

            p.currentKey = "UNASSIGNED";
            p.isUnassigned = true;
            p.moved = true;
            let seniorsInMyBase = bidders.filter(other => other.sen < p.sen && other.currentKey === p.orig).length;
            const selfBid = p.prefs.find(pr => pr.targetKey === p.orig);
            p.wasSelfDisplaced = selfBid && (seniorsInMyBase + 1) > selfBid.bpl;
            p.awardedReason = p.wasSelfDisplaced ? 
                `BPL Failure (Rank ${seniorsInMyBase + 1} > Limit ${selfBid.bpl}). Increase ${p.orig} vacancy ${origOldVac} → ${origNewVac}.` : 
                `Displaced: System-wide Reduction. Increase ${p.orig} vacancy ${origOldVac} → ${origNewVac}.`;
            
            p.bidLog.push(`<div class="log-fail">Final Action: Displaced to Pool</div>`);
        }
    });

    return { roster: bidders, targetMap };
}

function exportToCSV(filename, rows) {
    const csvContent = rows.map(row => row.map(cell => `"${String(cell ?? "").replace(/<[^>]*>/g, '').replace(/\n/g, ' ').replace(/"/g, '""')}"`).join(",")).join("\n");
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement("a");
    link.setAttribute("href", URL.createObjectURL(blob));
    link.setAttribute("download", filename);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}

window.onload = async () => {
    try {
        const files = ['roster.json', 'preferences.json', 'capacities.json', 'retired_pilots.json', 'nobidpilots.json'];
        const results = await Promise.all(files.map(async f => { const r = await fetch(f); return await r.json(); }));
        store = { roster: results[0], prefs: results[1], caps: results[2], retired: results[3], noBid: results[4] };
        renderCapacities();
    } catch (e) { document.body.innerHTML = `<div style="padding:40px; color:red">🚨 ERROR: ${e.message}</div>`; }
};

function renderCapacities() {
    document.getElementById('capGrid').innerHTML = store.caps.map(c => {
        let displayCap = c.startCapacity;
        if (c.base === "LAX" && c.seat === "CA") displayCap = 189;
        if (c.base === "SFO" && c.seat === "CA") displayCap = 153;
        return `<div class="cap-cell"><label>${c.base} ${c.seat} (Hard Cap: ${displayCap})</label><input type="number" id="delta-${c.base}-${c.seat}" value="${c.delta || 0}"></div>`;
    }).join('');
}

document.getElementById('runBtn').onclick = () => {
    const deltas = {};
    store.caps.forEach(c => { const el = document.getElementById(`delta-${c.base}-${c.seat}`); if (el) deltas[`${c.base}-${c.seat}`.toUpperCase()] = parseInt(el.value) || 0; });
    const result = runBidEngine(store, deltas);
    lastResults = result.roster;
    lastTargetMap = result.targetMap;
    renderTable(lastResults, lastTargetMap);
    renderDashboards(lastResults);
};

function renderDashboards(roster) {
    let unassignedHtml = '', moverHtml = '', selfDispHtml = '';
    roster.forEach(p => {
        const item = `<div>#${p.sen} ${p.name}: ${p.awardedReason}</div>`;
        if (p.isUnassigned) unassignedHtml += item;
        if (p.wasSelfDisplaced) selfDispHtml += item;
        if (p.moved && !p.isUnassigned) moverHtml += `<div>#${p.sen} ${p.name} from ${p.orig}</div>`;
    });
    document.getElementById('unassignedList').innerHTML = unassignedHtml || "None.";
    document.getElementById('selfDispList').innerHTML = selfDispHtml || "None.";
    document.getElementById('displacedList').innerHTML = moverHtml || "None.";
}

function renderTable(roster, targetMap) {
    document.getElementById('tableBody').innerHTML = roster.map(p => {
        const awardedPos = p.currentKey.replace('-', ' ');
        let tags = '';
        if (p.wasSelfDisplaced) tags += '<span class="tag tag-red">SELF-DISPLACED</span>';
        else if (p.isUnassigned) tags += '<span class="tag" style="background:var(--purple); color:white;">DISPLACED</span>';
        else if (p.moved) tags += '<span class="tag tag-yellow">MOVER</span>';
        
        let finalRank = 0;
        if (p.currentKey !== "UNASSIGNED") roster.forEach(other => { if (other.sen <= p.sen && other.currentKey === p.currentKey) finalRank++; });
        
        return `<tr>
            <td>${p.sen}</td>
            <td><strong>${p.name}</strong><br>${tags}</td>
            <td style="color:${p.moved && !p.isUnassigned ?'#3fb950':''}">${awardedPos}</td>
            <td><span class="rank-badge">${p.currentKey === "UNASSIGNED" ? "-" : finalRank + " / " + (targetMap[p.currentKey] || 0)}</span></td>
            <td>
                <strong>${p.awardedReason}</strong>
                <div class="bid-log">${p.bidLog.join('')}</div>
            </td>
            <td>${p.orig.replace('-',' ')}</td>
        </tr>`;
    }).join('');
}

document.getElementById('expMaster').onclick = () => {
    const headers = ["Sen #", "Name", "Awarded Position", "Standing (Rank / Limit)", "Award Summary", "Full Evaluation Log", "Original Position"];
    const rows = lastResults.map(p => {
        let finalRank = 0;
        if (p.currentKey !== "UNASSIGNED") lastResults.forEach(other => { if (other.sen <= p.sen && other.currentKey === p.currentKey) finalRank++; });
        const standing = p.currentKey === "UNASSIGNED" ? "-" : `${finalRank} / ${lastTargetMap[p.currentKey] || 0}`;
        return [p.sen, p.name, p.currentKey, standing, p.awardedReason, p.bidLog.join(' | '), p.orig];
    });
    exportToCSV("master_awards.csv", [headers, ...rows]);
};

document.getElementById('expBase').onclick = () => {
    const headers = ["Position", "Seniority", "Name", "Rank"];
    const rows = [];
    Object.keys(lastTargetMap).forEach(key => {
        const basePilots = lastResults.filter(p => p.currentKey === key).sort((a,b) => a.sen - b.sen);
        basePilots.forEach((p, idx) => rows.push([key, p.sen, p.name, idx + 1]));
    });
    exportToCSV("base_lists.csv", [headers, ...rows]);
};

document.getElementById('expLog').onclick = () => {
    const headers = ["Seniority", "Name", "From", "To", "Transition Note"];
    const rows = lastResults.filter(p => p.moved).map(p => [p.sen, p.name, p.orig, p.currentKey, p.awardedReason]);
    exportToCSV("transition_log.csv", [headers, ...rows]);
};
</script>
</body>
</html>
